OOAI_SKILLS_S3_ENDPOINT=http://localhost:9000
OOAI_SKILLS_S3_ACCESS_KEY=minioadmin
OOAI_SKILLS_S3_SECRET_KEY=minioadmin
OOAI_SKILLS_S3_SECURE=false
OOAI_SKILLS_S3_REGION=us-east-1

OOAI_SKILLS_BUCKET=agent-skills
OOAI_SKILLS_LOCAL_PACKS_DIR=~/.agents/skillpacks
OOAI_SKILLS_LOCAL_SKILLS_DIR=~/.agents/skills
OOAI_SKILLS_WORK_DIR=~/.cache/ooai-skills

# Extra targets: comma-separated paths that also receive the flattened skill view.
# Default: ~/.claude/skills (Claude Code integration).
# Set to empty string to disable.
OOAI_SKILLS_EXTRA_TARGETS=~/.claude/skills
